  - character: player
    expression: "\u9ED8\u8BA4"
    text: "\u8FD9\u4E2A\u6E38\u620F\u771F\u6709\u610F\u601D\uFF0C\u6211\u5F88\u671F\u5F85\u5B8C\u5168\u7248\uFF01"
  - character: player
    expression: "\u5F00\u5FC3\u95ED\u773C"
    text: "\u54C8\u54C8\uFF0C\u8FD9\u6B21\u7684\u7FFB\u8BD1\u771F\u6709\u610F\u601D\uFF01"
  - character: player
    expression: "\u9ED8\u8BA4"
    text: "\u8FD9\u6B21\u7684\u4E3B\u89D2\u8BBE\u8BA1\u771F\u7CBE\u5F69\uFF0C\u6BCF\u4E2A\u8868\u60C5\u90FD\u7279\u522B\u751F\u52A8\u3002"
  - character: player
    expression: "\u60CA\u8BB6"
    text: "\u8FD9\u662F\u4EC0\u4E48\uFF01\u6211\u88AB\u8BF4\u670D\u4E86\uFF01"
  - character: player
    expression: "\u65E0\u8BED"
    text: "\u2026\u2026\u6211\u8FD8\u662F\u5148\u770B\u770B\u5427\u3002"
  - character: player
    expression: "\u96BE\u8FC7"
    text: "\u53EA\u662F\u770B\u770B\u8FD9\u4E2A\u5C0F\u6545\u4E8B\u5C31\u597D\u4E86\u2026\u2026"
  - character: player
    expression: "\u96BE\u8FC7\u95ED\u773C"
    text: "\u8FD9\u4E2A\u60C5\u8282\u771F\u8BA9\u4EBA\u611F\u52A8\u2026\u2026"
  - character: player
    expression: "\u751F\u6C14"
    text: "\u53EF\u6076\uFF01\u600E\u4E48\u80FD\u8FD9\u6837\uFF01"
  - character: player
    expression: "\u751F\u6C14\u95ED\u773C"
    text: "\u54E6\uFF0C\u6211\u5C31\u662F\u8FD9\u6837\u4E86\uFF0C\u600E\u4E48\u600E\uFF01"
  - character: player
    expression: "\u60CA\u614C"
    text: "\u7A0D\u7A0D\u7A0D\u7A0D\u2026\u2026\u8FD9\u662F\u600E\u4E48\u56DE\u4E8B\uFF01"
  - character: player
    expression: "\u9ED8\u8BA4"
    text: "\u7EC8\u4E8E\u7B97\u662F\u5F00\u59CB\u4E86\u2026\u2026\u6211\u4EEC\u7684\u6545\u4E8B\u3002"
